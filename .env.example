# Supabase (client-side — safe to expose)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe (client-side — safe to expose)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe (server-side — Netlify Functions only, never expose)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Supabase service role (server-side — Netlify Functions only, never expose)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (server-side — Netlify Functions only, never expose)
ANTHROPIC_API_KEY=sk-ant-...
